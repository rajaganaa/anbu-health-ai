# Anbu Health AI — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to GitHub

# ── LLM ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Vision AI ──────────────────────────────────────────────────────────
# Get from: github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_your_github_token_here

# ── Vector DB (Qdrant Cloud) ───────────────────────────────────────────
# Sign up free: cloud.qdrant.io
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# ── Database (Supabase) ────────────────────────────────────────────────
# Sign up free: supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Auth (MSG91 OTP) ───────────────────────────────────────────────────
# Sign up: msg91.com
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_template_id

# ── MLOps ──────────────────────────────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=anbu-health-ai
WANDB_ENTITY=rajaganaa-ai

# ── App ────────────────────────────────────────────────────────────────
PORT=8000
ANBU_DATA_DIR=./data/drug_guides
UPLOAD_DIR=/tmp/anbu_uploads
